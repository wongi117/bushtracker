{
  // ── Flutter / Dart ──────────────────────────────────────────
  "dart.flutterSdkPath": null,
  "dart.debugExternalPackageLibraries": false,
  "dart.debugSdkLibraries": false,
  "dart.previewFlutterUiGuides": true,
  "dart.previewFlutterUiGuidesCustomTracking": true,
  "dart.showTodos": true,
  "dart.lineLength": 100,
  "dart.insertArgumentPlaceholders": true,
  "dart.completeFunctionCalls": true,
  "dart.warnWhenEditingFilesOutsideWorkspace": true,
  "dart.hotReloadOnSave": "allFiles",
  "dart.flutterHotRestartOnSave": false,

  // ── Editor ──────────────────────────────────────────────────
  "[dart]": {
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.formatOnSave": true,
    "editor.formatOnType": false,
    "editor.rulers": [100],
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.tabSize": 2,
    "editor.wordBasedSuggestions": "off"
  },
  "editor.fontSize": 14,
  "editor.fontFamily": "Fira Code, Cascadia Code, Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.tabSize": 2,
  "editor.minimap.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.inlayHints.enabled": "on",
  "editor.stickyScroll.enabled": true,
  "editor.suggestSelection": "first",

  // ── Files ───────────────────────────────────────────────────
  "files.autoSave": "onFocusChange",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.dart_tool": true,
    "**/.flutter-plugins": true,
    "**/.flutter-plugins-dependencies": true,
    "**/build": true,
    "**/*.g.dart": false
  },
  "search.exclude": {
    "**/build": true,
    "**/.dart_tool": true,
    "**/ios/Pods": true,
    "**/android/.gradle": true
  },

  // ── Flutter run args — loads .env keys for local dev ────────
  "dart.flutterRunAdditionalArgs": [
    "--dart-define-from-file=.env"
  ],
  "dart.flutterTestAdditionalArgs": [
    "--dart-define-from-file=.env"
  ],

  // ── Explorer ────────────────────────────────────────────────
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "pubspec.yaml": "pubspec.lock, .flutter-plugins, .flutter-plugins-dependencies, analysis_options.yaml",
    "*.dart": "${capture}.g.dart, ${capture}.freezed.dart"
  },

  // ── Terminal ────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.fontSize": 13
}
